# =============================================================================
# 多智能體投研 pipeline — NAS / server crontab 範例
# =============================================================================
# 這是「首選」排程方式:三個 SQLite DB 通常在 NAS/本機,cron 直接在同一台跑最單純。
#
# 安裝:  crontab -e  然後貼上下面兩行(改成你的實際路徑)。
#
# ⚠️ 時區:cron 用「機器本地時區」。以下假設機器為台灣時間(UTC+8)。
#         若機器是 UTC:早上 07:30 TW = 前一日 23:30 UTC→改「30 23 * * 0-4」(週日~四);
#         下午 16:30 TW = 當日 08:30 UTC→改「30 8 * * 1-5」。
#         查機器時區:  timedatectl  或  date
#
# ⚠️ 時點原則(對照憲法 §2.3 發布延遲):
#   - 早上場 07:30:開盤前(09:00 開盤前)。用「前一日收盤 + 隔夜美股(fund.db) + 隔夜新聞」→ 當日盤前計畫。
#   - 下午場 16:30:台股 13:30 收盤後。用「當日已結算收盤」→ 收盤後調整。
#     ★ 若你的 stock.db 是收盤後較晚(如 17:00)才更新,請把下午場再往後移到更新之後,
#       否則 freshness 守門會告警(這正是它的用途:防止跑在舊資料上)。
#
# 週一至週五(1-5)才跑;台股週末休市。
# -----------------------------------------------------------------------------

# 環境變數(三個 DB 路徑;可選:注入真實總經值 + LINE 推播 + 清單共享)
STOCK_DB=/volume1/data/stock.db
FUND_DB=/volume1/data/fund.db
NEWS_DB=/volume1/data/news.db
# FINMIND_TOKEN=xxxxx                  # STEP 1 my-stock export 的 live 表(技術/籌碼/月營收)才需;離線層免
# MACRO_SPREAD_PCT=0.85
# MACRO_CPI_YOY_PCT=3.10
# LINE_CHANNEL_ACCESS_TOKEN=xxxxx     # 設了才會實際推 LINE
# LINE_TO=Uxxxxxxxx                    # 推播對象 userId / groupId
# GITHUB_TOKEN=github_pat_xxx          # 清單共享(webhook 寫 / cron 讀 同一份;見 shared_watchlist.md)
# GITHUB_REPO=linchen-20200325/2026_strategy_0719

# =============================================================================
# STEP 1｜三個源專案各自 export → 寫進上面共享 DB 路徑（**必須排在 pipeline 之前**）
# =============================================================================
# 「各源專案各自 export」架構:抓取/評分留在各自 repo,2026 只讀三庫判讀。
# 時序鐵則(對照憲法 §2.3):export 先跑完、pipeline 再判讀,中間留 ~30-40 分緩衝。
#   盤前 06:50 export → 07:30 pipeline;收盤後 16:00 export → 16:30 pipeline。
#   ★ stock.db 收盤後若較晚更新(如 my-stock update_macro_history 17:00 TW),把「收盤後」整組往後移。
# 路徑改成你 NAS 上三個 repo 的實際位置;export 讀上面的 STOCK_DB/FUND_DB/NEWS_DB 環境變數。
# my-stock 的技術/籌碼/月營收 live 表需 FINMIND_TOKEN(上面設);離線層(財報/指數/法人)免 key。

# 盤前 06:50（給 07:30 pipeline 用）
50 6 * * 1-5  cd /path/to/mynews             && /usr/bin/python3 export_news_db.py          >> /path/to/2026_strategy_0719/logs/export.log 2>&1
50 6 * * 1-5  cd /path/to/my-stock-dashboard && /usr/bin/python3 scripts/export_stock_db.py >> /path/to/2026_strategy_0719/logs/export.log 2>&1
50 6 * * 1-5  cd /path/to/my-Fund-dashboard  && /usr/bin/python3 scripts/export_fund_db.py  >> /path/to/2026_strategy_0719/logs/export.log 2>&1
# 收盤後 16:00（給 16:30 pipeline 用;stock.db 較晚更新則往後移）
0 16 * * 1-5  cd /path/to/mynews             && /usr/bin/python3 export_news_db.py          >> /path/to/2026_strategy_0719/logs/export.log 2>&1
0 16 * * 1-5  cd /path/to/my-stock-dashboard && /usr/bin/python3 scripts/export_stock_db.py >> /path/to/2026_strategy_0719/logs/export.log 2>&1
0 16 * * 1-5  cd /path/to/my-Fund-dashboard  && /usr/bin/python3 scripts/export_fund_db.py  >> /path/to/2026_strategy_0719/logs/export.log 2>&1

# =============================================================================
# STEP 2｜推播（mynews 風格分工）:①市場快訊 broadcast 全體 + ②個股盯盤 per-user 逐人。
# 兩者內容不同、不重複,可同時跑。國際情勢要真值 → 取消上面 MACRO_* 兩行的註解(從 my-stock 帶入)。
# =============================================================================

# ── ① 市場快訊(國際情勢 + 台股)→ broadcast 全體好友(同 mynews 主報告;免 LINE_TO)──
30 7 * * 1-5  cd /path/to/2026_strategy_0719 && /usr/bin/python3 run_pipeline.py --session morning   --market-digest >> logs/pipeline.log 2>&1
30 16 * * 1-5 cd /path/to/2026_strategy_0719 && /usr/bin/python3 run_pipeline.py --session afternoon --market-digest >> logs/pipeline.log 2>&1

# ── ② 個股盯盤 → per-user 逐人(每位訂閱者各自清單全列:判讀＋技術＋籌碼一張卡;免 LINE_TO)──
# 前提:subscribers.json 由 scripts/nas_line_bot.py(webhook)維護,--subscribers 路徑要與
#       webhook 的 SUBSCRIBERS_FILE 一致(見 deploy/nas_line_bot.md / shared_watchlist.md)。
#       先 dry-run 驗:  python3 run_pipeline.py --session afternoon --per-user --dry-run
30 7 * * 1-5  cd /path/to/2026_strategy_0719 && /usr/bin/python3 run_pipeline.py --session morning   --per-user --subscribers /volume1/data/subscribers.json >> logs/pipeline.log 2>&1
30 16 * * 1-5 cd /path/to/2026_strategy_0719 && /usr/bin/python3 run_pipeline.py --session afternoon --per-user --subscribers /volume1/data/subscribers.json >> logs/pipeline.log 2>&1

# ── (替代) 只想要一份簡易群發 per-stock 摘要(不分國際/台股)→ 用 --line + LINE_TO ──
# 30 16 * * 1-5 cd /path/to/2026_strategy_0719 && /usr/bin/python3 run_pipeline.py --session afternoon --line --output logs/afternoon.json >> logs/pipeline.log 2>&1

# 提示:加 --strict 可讓「資料過期就中止並回傳非 0」,方便被監控偵測。
